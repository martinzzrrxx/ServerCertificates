<Window x:Class="ServerCertViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:ServerCertViewer.Models"
        mc:Ignorable="d"
        Title="HTTPS Certificate Chain Viewer"
        Width="1040"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="#FFF5F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="CardExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD6DFEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              Margin="0"
                                              Padding="18,16"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              FocusVisualStyle="{x:Null}"
                                              Foreground="#FF1E293B"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              HorizontalContentAlignment="Stretch"
                                              FontSize="15">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Stretch" />
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Margin="18,0,18,18"
                                                  ContentSource="Content"
                                                  HorizontalAlignment="Stretch"
                                                  Visibility="Collapsed" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="18"
                Background="#FFF8FAFC"
                BorderBrush="#FFD9E2EC"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Foreground="#FF334155"
                           FontWeight="SemiBold"
                           Text="HTTPS URL" />
                <TextBox Grid.Row="1"
                         Margin="0,8,12,0"
                         Padding="12,10"
                         FontSize="15"
                         Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Padding="22,10"
                        Click="FetchCertificates_Click"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#FF0F766E"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Content="Fetch Chain" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Margin="0,0,0,12"
                       Foreground="#FF475569"
                       FontSize="14"
                       Text="{Binding StatusMessage}" />

            <Grid Grid.Row="1">
                <Border Padding="24"
                        Background="White"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#FF0F172A"
                                   Text="Certificate Chain" />

                        <Grid Grid.Row="1">
                            <ScrollViewer Margin="0,18,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Certificates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type model:CertificateViewItem}">
                                            <Expander Style="{StaticResource CardExpanderStyle}">
                                                <Expander.Header>
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="42"
                                                                Height="42"
                                                                Margin="0,0,14,0"
                                                                Background="#FFE2F7F5"
                                                                CornerRadius="21">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF0F766E"
                                                                       Text="{Binding DisplayIndex}" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock FontSize="16"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF0F172A"
                                                                       Text="{Binding DisplayName}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Foreground="#FF475569"
                                                                       Text="{Binding ChainPosition}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="#FF64748B"
                                                                       Text="{Binding Subject}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#FF0F766E"
                                                                   FontWeight="SemiBold"
                                                                   Text="View Details" />
                                                    </Grid>
                                                </Expander.Header>

                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Margin="0,6,20,0">
                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Subject" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Subject}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Issuer" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Issuer}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Thumbprint" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Thumbprint}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Serial Number" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SerialNumber}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Valid From" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding NotBefore}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Valid Until" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding NotAfter}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="20,6,0,0">
                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Version" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Version}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Signature Algorithm" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SignatureAlgorithm}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Public Key" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding PublicKeyAlgorithm}" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding PublicKeyLength}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Subject Alternative Names" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SubjectAlternativeNames}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Basic Constraints" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BasicConstraints}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Key Usage" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding KeyUsage}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Enhanced Key Usage" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding EnhancedKeyUsage}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding EmptyStateVisibility}">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="42"
                                           Foreground="#FFCBD5E1"
                                           Text="Certificates" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#FF64748B"
                                           FontSize="15"
                                           Text="No certificate chain loaded yet. Enter an HTTPS URL to begin." />
                            </StackPanel>

                            <Border Background="#B3FFFFFF"
                                    CornerRadius="18"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <ProgressBar Width="200"
                                                 Height="8"
                                                 IsIndeterminate="True" />
                                    <TextBlock Margin="0,12,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="#FF334155"
                                               Text="Connecting with TLS and reading the certificate chain..." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
