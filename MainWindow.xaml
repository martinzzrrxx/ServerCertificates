<Window x:Class="ServerCertViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:ServerCertViewer.Models"
        mc:Ignorable="d"
        Title="HTTPS Certificate Chain Viewer"
        Width="1040"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="#FFF5F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#FFB7CAD9"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="10" />
                                <Setter Property="Width" Value="Auto" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="False">
                    <Setter Property="Opacity" Value="0.78" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD6DFEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border x:Name="HeaderBackground"
                                        Background="Transparent"
                                        CornerRadius="14">
                                    <ToggleButton x:Name="HeaderSite"
                                                  Margin="0"
                                                  Padding="18,16"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  FocusVisualStyle="{x:Null}"
                                                  Foreground="#FF1E293B"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  HorizontalContentAlignment="Stretch"
                                                  FontSize="15">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      Content="{TemplateBinding Content}"
                                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Stretch" />
                                    </ToggleButton>
                                </Border>

                                <Border x:Name="ContentBackground"
                                        Grid.Row="1"
                                        Background="White"
                                        CornerRadius="0,0,14,14"
                                        Visibility="Collapsed">
                                    <ContentPresenter x:Name="ExpandSite"
                                                      Margin="18,0,18,18"
                                                      ContentSource="Content"
                                                      HorizontalAlignment="Stretch" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="HeaderSite" Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#FFEAF4FB" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#FFD4E9F6" />
                                <Setter TargetName="HeaderBackground" Property="CornerRadius" Value="14,14,0,0" />
                                <Setter TargetName="ContentBackground" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition SourceName="HeaderSite" Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsExpanded" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#FFC7E0F2" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="StatusChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="#FFE2E8F0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ValidationSeverity}" Value="{x:Static model:ValidationSeverity.Error}">
                    <Setter Property="Background" Value="#FFFEE2E2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ValidationSeverity}" Value="{x:Static model:ValidationSeverity.Warning}">
                    <Setter Property="Background" Value="#FFFEF3C7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ValidationSeverity}" Value="{x:Static model:ValidationSeverity.Info}">
                    <Setter Property="Background" Value="#FFDCFCE7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF166534" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ValidationSeverity}" Value="{x:Static model:ValidationSeverity.Error}">
                    <Setter Property="Foreground" Value="#FFB91C1C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ValidationSeverity}" Value="{x:Static model:ValidationSeverity.Warning}">
                    <Setter Property="Foreground" Value="#FF92400E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD6DFEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF94A3B8" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFB8C4D1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0F766E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF115E59" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF134E4A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="16"
                Background="#FFF8FAFC"
                BorderBrush="#FFD9E2EC"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Foreground="#FF334155"
                           FontWeight="SemiBold"
                           Text="HTTPS URL" />
                <TextBox Grid.Row="1"
                         Margin="0,8,12,0"
                         FontSize="15"
                         Style="{StaticResource RoundedTextBoxStyle}"
                         Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Click="FetchCertificates_Click"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Style="{StaticResource RoundedActionButtonStyle}"
                        Content="Fetch Chain" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Margin="0,0,0,8"
                       Foreground="#FF475569"
                       FontSize="14"
                       Text="{Binding StatusMessage}" />

            <Grid Grid.Row="1">
                <Border Padding="18"
                        Background="White"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#FF0F172A"
                                       Text="Certificate Chain" />
                            <Border Margin="10,2,0,0"
                                    Padding="8,3"
                                    Background="#FFFEE2E2"
                                    CornerRadius="7"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding HasValidationError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#FFB91C1C"
                                           Text="Invalid server certificate chain" />
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <ScrollViewer Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.CanContentScroll="True">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <ItemsControl Margin="0,0,14,0"
                                              ItemsSource="{Binding Certificates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type model:CertificateViewItem}">
                                            <Expander Style="{StaticResource CardExpanderStyle}">
                                                <Expander.Header>
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="42"
                                                                Height="42"
                                                                Margin="0,0,14,0"
                                                                Background="#FFE2F7F5"
                                                                CornerRadius="21">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF0F766E"
                                                                       Text="{Binding DisplayIndex}" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontSize="16"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF0F172A"
                                                                           Text="{Binding DisplayName}" />
                                                                <Border Margin="10,0,0,0"
                                                                        VerticalAlignment="Center"
                                                                        Style="{StaticResource StatusChipStyle}">
                                                                    <TextBlock Style="{StaticResource StatusChipTextStyle}"
                                                                               Text="{Binding ValidationStatusLabel}" />
                                                                </Border>
                                                            </StackPanel>

                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="#FF475569"
                                                                       Text="{Binding ChainPosition}" />

                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="#FF64748B"
                                                                       Text="{Binding Subject}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="#FF64748B"
                                                                       FontSize="12"
                                                                       Text="{Binding ValidationSummary}"
                                                                       Visibility="{Binding HasValidationIssues, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#FF0F766E"
                                                                   FontWeight="SemiBold"
                                                                   Text="View Details" />
                                                    </Grid>
                                                </Expander.Header>

                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.ColumnSpan="2"
                                                            Margin="0,10,0,14"
                                                            Padding="14"
                                                            Background="#FFFEF2F2"
                                                            BorderBrush="#FFFECACA"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Border.Visibility>
                                                            <Binding Path="HasValidationIssues"
                                                                     Converter="{StaticResource BooleanToVisibilityConverter}" />
                                                        </Border.Visibility>
                                                        <StackPanel>
                                                            <TextBlock FontWeight="Bold"
                                                                       Foreground="#FFB91C1C"
                                                                       Text="Validation Issues" />
                                                            <ItemsControl Margin="0,10,0,0"
                                                                          ItemsSource="{Binding ValidationIssues}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="0,0,0,8"
                                                                                Padding="10"
                                                                                Background="#FFFFFFFF"
                                                                                BorderBrush="#FFFECACA"
                                                                                BorderThickness="1"
                                                                                CornerRadius="10">
                                                                            <StackPanel>
                                                                                <TextBlock FontWeight="SemiBold"
                                                                                           Foreground="#FFB91C1C"
                                                                                           Text="{Binding Title}" />
                                                                                <TextBlock Margin="0,4,0,0"
                                                                                           Foreground="#FF475569"
                                                                                           Text="{Binding Message}"
                                                                                           TextWrapping="Wrap" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>

                                                    <StackPanel Grid.Row="1"
                                                                Margin="0,6,20,0">
                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Subject" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Subject}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Issuer" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Issuer}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Thumbprint" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Thumbprint}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Serial Number" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SerialNumber}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Valid From" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding NotBefore}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Valid Until" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding NotAfter}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1"
                                                                Grid.Column="1"
                                                                Margin="20,6,0,0">
                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Version" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Version}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Signature Algorithm" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SignatureAlgorithm}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Public Key" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding PublicKeyAlgorithm}" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding PublicKeyLength}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Subject Alternative Names" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SubjectAlternativeNames}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Basic Constraints" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BasicConstraints}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Key Usage" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding KeyUsage}" />

                                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Enhanced Key Usage" />
                                                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding EnhancedKeyUsage}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding EmptyStateVisibility}">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="42"
                                           Foreground="#FFCBD5E1"
                                           Text="Certificates" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#FF64748B"
                                           FontSize="15"
                                           Text="No certificate chain loaded yet. Enter an HTTPS URL to begin." />
                            </StackPanel>

                            <Border Background="#B3FFFFFF"
                                    CornerRadius="18"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <ProgressBar Width="200"
                                                 Height="8"
                                                 IsIndeterminate="True" />
                                    <TextBlock Margin="0,12,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="#FF334155"
                                               Text="Connecting with TLS and reading the certificate chain..." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
